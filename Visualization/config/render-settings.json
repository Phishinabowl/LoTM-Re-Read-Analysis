{
  "puppeteerConfig": "Visualization/config/puppeteer-config.json",
  "background": "white",
  "width": 2400,
  "height": 1800,
  "pngScale": 2,
  "autoSize": {
    "enabled": true,
    "complexityUnit": 40,
    "widthStep": 1200,
    "heightStep": 600,
    "fanOutThreshold": 6,
    "fanOutWidthStep": 900,
    "maxWidth": 7200,
    "maxHeight": 5400
  },
  "classValidation": {
    "enabled": true,
    "requireClassesWhenGraphUsesClasses": true,
    "uncertaintyClasses": [
      "uncertain",
      "boundary",
      "note"
    ],
    "uncertaintyClassStylePattern": "stroke-dasharray",
    "semanticPatterns": [
      {
        "className": "sequence",
        "patterns": [
          "(^|_)seq(uence)?[0-9_]",
          "(^|_)seer[0-9_]",
          "(^|_)unknown$"
        ]
      }
    ],
    "labelRoleRules": [
      {
        "description": "Ordered sequence or step labels should use a progression role class.",
        "patterns": [
          "^Seq\\s*[0-9]",
          "^Sequence\\s*[0-9]",
          "^Step\\s*[0-9]",
          "^Phase\\s*[0-9]",
          "^Stage\\s*[0-9]",
          "^Rank\\s*[0-9]",
          "^Level\\s*[0-9]"
        ],
        "allowedClasses": [
          "sequence",
          "step",
          "stage"
        ]
      },
      {
        "description": "Holder labels should use a holder or uncertainty role class.",
        "patterns": [
          "^holder:",
          "^holders:",
          "^generic holder:"
        ],
        "allowedClasses": [
          "holder",
          "uncertain"
        ]
      },
      {
        "description": "Uncertain, inferred, missing, or boundary labels should use an uncertainty role class.",
        "patterns": [
          "^likely ",
          "^suspected ",
          "^holder-like:",
          "^prospective holder:",
          "inferred",
          "likely",
          "suspected",
          "unknown",
          "uncertain",
          "not confirmed",
          "not revealed",
          "missing",
          "boundary"
        ],
        "allowedClasses": [
          "uncertain",
          "boundary",
          "note"
        ]
      }
    ]
  },
  "layoutValidation": {
    "enabled": true,
    "sectionClassNames": [
      "group"
    ],
    "crossSectionTargetClasses": [
      "holder",
      "sequence"
    ],
    "duplicateLabelIgnoreClasses": [
      "relationship"
    ],
    "proxyNodeIdPatterns": [
      "(^|_)ref(erence)?$",
      "(^|_)proxy$",
      "_ref_",
      "_proxy_"
    ],
    "proxyLabelPatterns": [
      "reference",
      "proxy",
      "see ",
      "reconstruction",
      "summary"
    ],
    "denseGraphValidation": {
      "enabled": true,
      "minNodeCount": 20,
      "requireClassDefinitions": true,
      "maxSubgraphCount": 4,
      "maxDisconnectedComponents": 2
    },
    "orderedSeriesValidation": {
      "enabled": true,
      "maxDirectChildren": 2,
      "childLabelPatterns": [
        "^Seq\\s*[0-9]",
        "^Sequence\\s*[0-9]",
        "^Ch(?:apter)?\\s*[0-9]",
        "^Episode\\s*[0-9]",
        "^Step\\s*[0-9]",
        "^Phase\\s*[0-9]",
        "^Stage\\s*[0-9]",
        "^Rank\\s*[0-9]",
        "^Level\\s*[0-9]"
      ]
    }
  },
  "reportPath": "Visualization/README.md",
  "snapshotPath": "Visualization/data/refresh-snapshot.json",
  "views": [
    {
      "name": "Volume 1 Knowledge Graph",
      "input": "Visualization/graphs/volume-1-knowledge-graph.mmd",
      "readerBoundary": {
        "medium": "novel",
        "maxVolume": 1,
        "maxChapter": 213,
        "includeUnknownSubjects": false,
        "includeUnknownPositions": false
      },
      "outputs": [
        "Visualization/rendered/volume-1-knowledge-graph.svg",
        "Visualization/rendered/volume-1-knowledge-graph.png"
      ]
    },
    {
      "name": "Volume 1 Knowledge Graph - Timing Spoiler-Free",
      "input": "Visualization/graphs/volume-1-knowledge-graph-timing-spoiler-free.mmd",
      "readerBoundary": {
        "medium": "novel",
        "maxVolume": 1,
        "maxChapter": 213,
        "includeUnknownSubjects": false,
        "includeUnknownPositions": false
      },
      "outputs": [
        "Visualization/rendered/volume-1-knowledge-graph-timing-spoiler-free.svg",
        "Visualization/rendered/volume-1-knowledge-graph-timing-spoiler-free.png"
      ]
    }
  ]
}
